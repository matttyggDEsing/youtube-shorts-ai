# ════════════════════════════════════════
# CONFIGURACIÓN DE YOUTUBE SHORTS AI
# ════════════════════════════════════════
# Copia este archivo como .env y completa los valores

# API Key de Groq (gratis en console.groq.com)
GROQ_API_KEY=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

# API Key de Pexels (gratis en pexels.com/api) — para B-roll cinematográfico
PEXELS_API_KEY=kCzoVLeGLZbfGammeUagW4i2OC5aQLf17BFT0l7r4el0zPOhAmExuI2n

# Puerto del servidor local
PORT=3000

# Nombre de tu canal (para el outro del video)
CHANNEL_NAME=Mi Canal de Historias

# Categoría por defecto al generar manualmente
DEFAULT_CATEGORY=terror

# Voz narradora por defecto
# Opciones: es-AR-ElenaNeural | es-MX-DaliaNeural | es-ES-AlvaroNeural | es-MX-JorgeNeural
DEFAULT_VOICE=es-AR-ElenaNeural

# Subir automáticamente a YouTube después de generar
AUTO_UPLOAD=false

# Directorios de trabajo
OUTPUT_DIR=./output
TEMP_DIR=./temp
